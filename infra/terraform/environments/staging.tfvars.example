# Copy to staging.tfvars and edit. staging.tfvars is gitignored (real values).
project_id  = "auto-workflow-staging-REPLACE"
region      = "asia-northeast3"
environment = "staging"

# ADR-020 §2 — Cloud SQL runs on Private IP; Cloud Run reaches it through
# the peered VPC + Auth Proxy sidecar. Flip `public_ip_enabled = true` only
# if you need a dev laptop to hit the instance without Auth Proxy (rare).
public_ip_enabled = false

# authorized_networks only applies when public_ip_enabled = true.
authorized_networks = [
  # { name = "dev-home", value = "203.0.113.10/32" },
]

# Cloud Run Direct VPC Egress subnet. Keep this non-overlapping with the
# services peering range (/16 allocated automatically) and with anything
# on your corp/home network if you ever tunnel in. /26 minimum — /28 runs
# out of assignable IPs under min_instance_count > 0 (see variables.tf).
cloudrun_subnet_cidr = "10.60.0.0/26"

# ADR-020 §6 — REQUIRED. No default. The hello bootstrap image was dropped
# because it fails the /health startup_probe. Bootstrap flow:
#   1. terraform apply -target=google_project_service.runtime_apis \
#        -target=google_artifact_registry_repository.images
#   2. docker build + push to AR
#   3. set the line below to the real tag and full `terraform apply`
# After that, CI updates images out-of-band (ignore_changes protects against
# revert), so this value stays as "the last image Terraform itself applied".
api_image_uri = "asia-northeast3-docker.pkg.dev/REPLACE-PROJECT/auto-workflow/api:REPLACE-TAG"

# ADR-021 §6 — Execution_Engine worker image. Same bootstrap flow as
# api_image_uri: build + push to AR first, then set this and full apply.
ee_image_uri = "asia-northeast3-docker.pkg.dev/REPLACE-PROJECT/auto-workflow/worker:REPLACE-TAG"

# Scale-to-zero by default (free at rest, ~2s cold start). Bump to 1 for
# demos / user tests — adds ~$7/month.
api_min_instances = 0
api_max_instances = 3

# APP_BASE_URL — set to the Cloud Run HTTPS URL after the first apply, then
# re-apply so email verification links point at the real host.
app_base_url = "http://localhost:8080"

# Public invoker — required for browsers / external webhooks to reach the
# API without an IAM token. Flip false once the Frontend is gated behind
# IAM-authenticated proxy / Identity-Aware Proxy.
api_allow_unauthenticated = true

# Safe to destroy staging on a whim; prod keeps the default true.
deletion_protection = false

# ---- AI_Agent (Modal pivot 2026-04-24) -------------------------------------
# 런타임은 Modal (AI_Agent/scripts/modal_app.py). GCP 쪽엔 백업 자산만 (AR 이미지
# 백업 + GCS GGUF 백업 + agent SA + bearer secret).
agent_region            = "us-central1"
agent_model_bucket_name = "REPLACE-PROJECT-agent-models-staging"
