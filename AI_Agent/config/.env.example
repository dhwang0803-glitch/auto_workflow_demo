# AI_Agent environment variables
# 복사해서 .env 로 사용: cp .env.example .env

# LLMBackend 선택 (PLAN_11 PR 1: stub/anthropic, PR 2: llamacpp 추가 예정)
LLM_BACKEND=stub

# Anthropic (LLM_BACKEND=anthropic 일 때)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# llama.cpp server (LLM_BACKEND=llamacpp 일 때 — PLAN_11 PR 2)
LLAMA_SERVER_URL=http://127.0.0.1:8080
