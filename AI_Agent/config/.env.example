# AI_Agent environment variables
# 복사해서 .env 로 사용: cp .env.example .env

# llama-server 내부 엔드포인트 (컨테이너 내 서브프로세스)
LLAMA_SERVER_URL=http://127.0.0.1:8080

# HuggingFace Hub — Gemma Terms 동의 후 read 토큰 발급
HF_TOKEN=

# 백엔드 선택 (런타임 토글)
LLM_BACKEND=llamacpp           # llamacpp|anthropic|stub
EMBEDDING_BACKEND=gemma_e2b    # gemma_e2b|bge_m3

# 모델 경로 (컨테이너 내부 경로)
GEMMA_MODEL_PATH=/models/gemma-4-26B-A4B-it-Q4_K_M.gguf

# 선택: dev/fallback 백엔드
ANTHROPIC_API_KEY=
