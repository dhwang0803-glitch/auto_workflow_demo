# API_Server local dev config — copy to .env and fill in.

# Async DSN for Postgres (matches Database/.env)
DATABASE_URL=postgresql+asyncpg://auto_workflow:auto_workflow@localhost:5435/auto_workflow

# JWT signing key — generate with `python -c "import secrets; print(secrets.token_urlsafe(48))"`
JWT_SECRET=dev-only-change-me-with-real-secret

# Which email backend to use: "console" prints links to the log, "smtp" (Phase 2) is NotImplementedError.
EMAIL_SENDER=console

# Base URL embedded in verification links (frontend origin in prod).
APP_BASE_URL=http://localhost:8000

# Fernet master key for credential-at-rest encryption (ADR-004, PLAN_07).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_MASTER_KEY=

